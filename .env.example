# Directum MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ─── Required for all servers (scaffold, validate, analyze, deploy) ───
# Absolute path to your Directum RX workspace root
# (the directory containing your package source/ folder)
SOLUTION_PATH=/path/to/your/directum-workspace

# ─── Required for directum-runtime server ───
# OData Integration Service URL of your Directum RX stand
RX_ODATA_URL=http://localhost/Integration/odata
# Service account credentials for OData Basic Auth
RX_USERNAME=Administrator
RX_PASSWORD=

# ─── Optional: Deploy server ───
# Path to DeploymentTool.exe (Windows) or DeploymentToolCore (Linux/macOS)
# DEPLOYMENT_TOOL_PATH=/opt/directum/DeploymentTool/DeploymentTool.exe
# Staging directory for .dat packages before publishing
# DEPLOYMENT_STAGING_PATH=/tmp/directum-staging

# ─── Optional: Runtime HTTP mode ───
# Port for HTTP transport (default: 3001, used with --http flag)
# RUNTIME_MCP_PORT=3001
# Comma-separated API keys for HTTP mode authentication
# MCP_API_KEYS=key1,key2
